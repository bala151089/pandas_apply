import pandas as pd

# sample df1
df1 = pd.DataFrame({
    "id": [1, 2, 3],
    "a": [10, 20, 30],
    "b": ["x", "y", "z"],   # string column
    "c": [1.5, 2.5, 3.5]    # float column
})

# sample df2
df2 = pd.DataFrame({
    "id": [1, 2, 3],
    "a": [None, 25, None],
    "b": ["xx", None, "zz"]
})
print(df1,df2)
# merge
df = df1.merge(df2, on="id", how="left", suffixes=("", "_df2"))

# columns to update
cols = [c for c in df2.columns if c != "id"]

for col in cols:
    # create overwrite column
    df[f"{col}_overwrite"] = df[f"{col}_df2"].combine_first(df[col])

    # match dtype with df1 column
    try:
        df[f"{col}_overwrite"] = df[f"{col}_overwrite"].astype(df[col].dtype)
    except:
        # fallback if conversion fails (mixed types)
        pass

# drop helper columns
df.drop(columns=[f"{c}_df2" for c in cols], inplace=True)

print(df)
print("\nDtypes:\n", df.dtypes)
