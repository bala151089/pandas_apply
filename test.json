import pandas as pd

# sample
df1 = pd.DataFrame({
    "id": [1,2,3],
    "a": [10,20,30],
    "b": [100,200,300]
})

df2 = pd.DataFrame({
    "id": [1,2,3],
    "a": [None,25,None],
    "b": [110,None,330]
})

# merge
df = df1.merge(df2, on="id", how="left", suffixes=("_df1", "_df2"))

# dynamically get common columns
cols = list(set(df1.columns).intersection(df2.columns))
cols.remove("id")

# apply logic
for col in cols:
    df[f"{col}_overwrite"] = df[f"{col}_df2"]   # from df2
    df[col] = df[f"{col}_df2"].combine_first(df[f"{col}_df1"])  # final value

# final output
out = df[["id"] + cols + [f"{c}_overwrite" for c in cols]]

print(out)
