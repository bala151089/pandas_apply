
def to_nested_dict(count_df, bal_df, persons=None):

    if not persons:
        persons = sorted(count_df["person"].unique())

    rcps = sorted(count_df["rcp"].unique())
    years = sorted(count_df["year"].unique())
    categories = ["Un(0)", "In(1)", "In(2)"]

    result = {}

    for person in persons:
        result[person] = {
            "count": {},
            "balance": {}
        }

        # -------- COUNT --------
        for year in years:
            result[person]["count"][year] = {}

            for rcp in rcps:
                result[person]["count"][year][rcp] = {}

                for cat in categories:
                    temp = count_df[
                        (count_df.person == person) &
                        (count_df.rcp == rcp) &
                        (count_df.year == year) &
                        (count_df.category == cat)
                    ]

                    if not temp.empty:
                        row = temp.iloc[0]
                        result[person]["count"][year][rcp][cat] = {
                            "count": int(row["count"]),
                            "%": float(round(row["%"], 2))
                        }
                    else:
                        result[person]["count"][year][rcp][cat] = {
                            "count": 0,
                            "%": 0.0
                        }

        # -------- BALANCE --------
        for year in years:
            result[person]["balance"][year] = {}

            for rcp in rcps:
                result[person]["balance"][year][rcp] = {}

                for cat in categories:
                    temp = bal_df[
                        (bal_df.person == person) &
                        (bal_df.rcp == rcp) &
                        (bal_df.year == year) &
                        (bal_df.category == cat)
                    ]

                    if not temp.empty:
                        row = temp.iloc[0]
                        result[person]["balance"][year][rcp][cat] = {
                            "balance": row["balance"],   # already formatted
                            "%": float(round(row["%"], 2))
                        }
                    else:
                        result[person]["balance"][year][rcp][cat] = {
                            "balance": "0.00",
                            "%": 0.0
                        }

    return result
