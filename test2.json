def create_pivot_tables(count_df, bal_df, persons=None):

    if not persons:
        persons = sorted(count_df["person"].dropna().unique())

    result = {}

    for person in persons:

        # ------------------ COUNT PIVOT ------------------
        cdf = count_df[count_df["person"] == person].copy()

        count_pivot = pd.pivot_table(
            cdf,
            index=["rcp", "category_label"],
            columns="year",
            values=["count", "%"],
            aggfunc="sum",
            fill_value=0
        )

        # reorder columns → (year -> count, %)
        count_pivot = count_pivot.swaplevel(0, 1, axis=1)
        count_pivot = count_pivot.sort_index(axis=1)

        # ------------------ BALANCE PIVOT ------------------
        bdf = bal_df[bal_df["person"] == person].copy()

        bal_pivot = pd.pivot_table(
            bdf,
            index=["rcp", "category_label"],
            columns="year",
            values=["balance", "%"],
            aggfunc="sum",
            fill_value=0
        )

        bal_pivot = bal_pivot.swaplevel(0, 1, axis=1)
        bal_pivot = bal_pivot.sort_index(axis=1)

        result[person] = {
            "count_pivot": count_pivot,
            "balance_pivot": bal_pivot
        }

    return result
